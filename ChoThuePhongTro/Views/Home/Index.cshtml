
@{
    ViewBag.Title = "Besnik";
}

<main>
    <!-- HERO -->
    <div class="hero">
        <div class="content">
            <div class="info">
                <p class="sub-title">Chào mừng đến với Besnik</p>
                <h1 class="title">Tìm kiếm nơi ở phù hợp với nhu cầu của bạn</h1>
                <p class="desc">
                    Tìm kiếm những phòng trọ tốt nhất hiện đang có trên thị trường!
                    Trao đổi và tìm kiếm thông tin phòng trọ dễ dàng và hấp dẫn chỉ với một tìm kiếm đơn giản.
                </p>
                <a href="#!" class="btn hero-cta">Tìm phòng ngay</a>
            </div>

            <img src="~/Content/assets/img/hero-img.svg" alt="Discover a place you'll love to live." class="hero-img">
        </div>
    </div>

    <!-- CLIENTS -->
    <div class="clients">
        <div class="content">
            <div class="row">
                <!-- Logo -->
                <img class="logo" src="~/Content/assets/img/Logo.svg" alt="Besnik">

                <!-- Stars -->
                <div class="stars">
                    <img src="~/Content/assets/img/Stars.svg" alt="Stars">
                </div>
            </div>
            <div class="row row-desc">
                <p class="desc">Hơn 4,500+ đơn vị cho thuê trọ tin tưởng Besnik</p>
                <p class="desc hide-on-mobile">Đánh giá 5 sao (hơn 2000 lượt đánh giá)</p>
            </div>
        </div>
    </div>

    <!-- GUIDES -->
    <div class="guides" id="services">
        <div class="content">
            <h2 class="sub-title">Có gì khác ngoài phòng trọ?</h2>
            <p class="desc">
                Ngoài phòng trọ thì chúng tôi còn cung cấp các loại hình dịch vụ cho thuê bất động sản khác như cho thuê nhà ở,
                cho thuê căn hộ, cho thuê mặt bằng,... gần như tất cả mọi dịch vụ đều có ở đây.
            </p>

            <!-- LIST GUIDES -->
            <ul class="list-guide">
                <li class="guide-item">
                    <img src="~/Content/assets/img/buyer.svg" alt="Buyer" class="icon">
                    <h3 class="title">Nhà cho thuê</h3>
                    <a href="#!" class="link">
                        <span>Tìm ngay</span>
                        <img src="~/Content/assets/img/arrow-right.svg" alt="arrow-right" class="arrow">
                    </a>
                </li>
                <li class="guide-item">
                    <img src="~/Content/assets/img/renter.svg" alt="Renter" class="icon">
                    <h3 class="title">Căn hộ cho thuê</h3>
                    <a href="#!" class="link">
                        <span>Tìm ngay</span>
                        <img src="~/Content/assets/img/arrow-right.svg" alt="arrow-right" class="arrow">
                    </a>
                </li>
                <li class="guide-item">
                    <img src="~/Content/assets/img/seller.svg" alt="Seller" class="icon">
                    <h3 class="title">Mặt bằng cho thuê</h3>
                    <a href="#!" class="link">
                        <span>Tìm ngay</span>
                        <img src="~/Content/assets/img/arrow-right.svg" alt="arrow-right" class="arrow">
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <!-- FEATURES -->
    <div class="features" id="features">
        <div class="content">
            <!-- HEADER -->
            <header>
                <h2 class="sub-title">Bất động sản nổi bật</h2>
                <div class="row">
                    <p class="desc">Mọi thứ bạn cần biết khi bạn đang tìm kiếm</p>
                    <a href="#!" class="link">
                        <span>Xem toàn bộ</span>
                        <img src="~/Content/assets/img/arrow-right.svg" alt="arrow-right" class="arrow">
                    </a>
                </div>
            </header>

            <!-- LIST -->
            <div class="list">
                <div class="item">
                    <a href="#!"><img src="~/Content/assets/img/featured-1.jpg" alt="CouCou Homestead" class="thumb"></a>
                    <div class="body">
                        <h3 class="title"><a href="#!" class="line-clamp">Phòng trọ tại quận 7</a></h3>
                        <p class="desc line-clamp">19 Nguyễn Hữu Thọ, phường Tân Phong, quận 7</p>
                        <div class="info">
                            <img src="~/Content/assets/img/bed.svg" alt="" class="icon">
                            <span class="label">2 giường ngủ</span>
                            <img src="~/Content/assets/img/both.svg" alt="" class="icon">
                            <span class="label">1 phòng tắm</span>
                            <img src="~/Content/assets/img/sqft.svg" alt="" class="icon">
                            <span class="label">20m2</span>
                        </div>
                    </div>
                </div>
                <div class="item">
                    <a href="#!"><img src="~/Content/assets/img/featured-2.jpg" alt="CouCou Homestead" class="thumb"></a>
                    <div class="body">
                        <h3 class="title"><a href="#!" class="line-clamp">Ký túc xá làng đại học Thủ Đức</a></h3>
                        <p class="desc line-clamp">19 Nguyễn Hữu Thọ, phường Tân Phong, TP. Thủ Đức</p>
                        <div class="info">
                            <img src="~/Content/assets/img/bed.svg" alt="" class="icon">
                            <span class="label">6 giường ngủ</span>
                            <img src="~/Content/assets/img/both.svg" alt="" class="icon">
                            <span class="label">2 phòng tắm</span>
                            <img src="~/Content/assets/img/sqft.svg" alt="" class="icon">
                            <span class="label">30m2</span>
                        </div>
                    </div>
                </div>
                <div class="item">
                    <a href="#!"><img src="~/Content/assets/img/featured-3.jpg" alt="CouCou Homestead" class="thumb"></a>
                    <div class="body">
                        <h3 class="title"><a href="#!" class="line-clamp">Căn hộ chung cư cao cấp tại quận 2</a></h3>
                        <p class="desc line-clamp">19 Nguyễn Hữu Thọ, phường Tân Phong, quận 2</p>
                        <div class="info">
                            <img src="~/Content/assets/img/bed.svg" alt="" class="icon">
                            <span class="label">3 giường ngủ</span>
                            <img src="~/Content/assets/img/both.svg" alt="" class="icon">
                            <span class="label">2 phòng tắm</span>
                            <img src="~/Content/assets/img/sqft.svg" alt="" class="icon">
                            <span class="label">40m2</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="view-all">
                <a href="#!" class="btn show-on-mobile">
                    <span>Tìm phòng ngay</span>
                </a>
            </div>
        </div>
    </div>

    <!-- STATS -->
    <div class="stats" id="resources">
        <div class="content">
            <div class="row">
                <div class="img-block">
                    <img src="~/Content/assets/img/stas-img.jpg" alt="" class="image" />
                    <div class="stats-trend">
                        <div class="row">
                            <strong class="value">40,000+</strong>
                            <img src="~/Content/assets/img/trend-up.svg" alt="" class="icon">
                        </div>
                        <p class="desc">Khách hàng kể từ khi Besnik có mặt trên thị trường</p>
                        <div class="seperate"></div>
                        <div class="avatar-block">
                            <div class="avatar-group">
                                <img src="~/Content/assets/img/avatar-1.jpg" alt="" class="avatar" />
                                <img src="~/Content/assets/img/avatar-2.jpg" alt="" class="avatar" />
                            </div>
                            <div class="avatar-group">
                                <img src="~/Content/assets/img/avatar-3.jpg" alt="" class="avatar" />
                                <img src="~/Content/assets/img/avatar-4.jpg" alt="" class="avatar" />
                                <img src="~/Content/assets/img/avatar-5.jpg" alt="" class="avatar" />
                                <div class="avatar">H</div>
                            </div>
                            <div class="avatar-group">
                                <img src="~/Content/assets/img/avatar-1.jpg" alt="" class="avatar" />
                                <img src="~/Content/assets/img/avatar-2.jpg" alt="" class="avatar" />
                                <img src="~/Content/assets/img/avatar-3.jpg" alt="" class="avatar" />
                            </div>
                            <div class="avatar-group">
                                <img src="~/Content/assets/img/avatar-4.jpg" alt="" class="avatar" />
                                <img src="~/Content/assets/img/avatar-5.jpg" alt="" class="avatar" />
                                <img src="~/Content/assets/img/avatar-6.jpg" alt="" class="avatar" />
                                <img src="~/Content/assets/img/avatar-1.jpg" alt="" class="avatar" />
                            </div>
                            <div class="avatar-group">
                                <img src="~/Content/assets/img/avatar-2.jpg" alt="" class="avatar" />
                                <img src="~/Content/assets/img/avatar-3.jpg" alt="" class="avatar" />
                            </div>
                            <div class="avatar-group">
                                <img src="~/Content/assets/img/avatar-4.jpg" alt="" class="avatar" />
                                <img src="~/Content/assets/img/avatar-5.jpg" alt="" class="avatar" />
                            </div>
                            <div class="avatar-group">
                                <img src="~/Content/assets/img/avatar-6.jpg" alt="" class="avatar" />
                                <img src="~/Content/assets/img/avatar-1.jpg" alt="" class="avatar" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="info">
                    <h2 class="sub-title">Bạn đã tìm thấy một khu phố mà bạn yêu thích?</h2>
                    <p class="desc">
                        Với Besnik, chúng tôi tin rằng sẽ đáp ứng được mọi nhu cầu về loại phòng cũng như địa điểm mà bạn đang ở.
                    </p>
                </div>

            </div>

            <div class="row row-qty">
                <div class="qty-item">
                    <strong class="qty">250+</strong>
                    <p class="qty-desc">Nhà cho thuê</p>
                </div>
                <div class="qty-item">
                    <strong class="qty">5,000+</strong>
                    <p class="qty-desc">Phòng trọ còn trống</p>
                </div>
                <div class="qty-item">
                    <strong class="qty">170+</strong>
                    <p class="qty-desc">Mặt bằng còn trống</p>
                </div>
            </div>
        </div>
    </div>

    <!-- SUBCRIPTION -->
    <div class="subcription" id="contact">
        <div class="content">
            <div class="body">
                <div class="info">
                    <h2 class="sub-title line-clamp">Đăng ký để nhận tin của chúng tôi</h2>
                    <p class="desc line-clamp">Đăng ký nhận bản tin của chúng tôi và cập nhật thông tin mới nhất.</p>
                    <a href="#!" class="btn">Đăng ký</a>
                </div>
                <img src="~/Content/assets/img/newletter.svg" alt="" class="image">
            </div>
        </div>
    </div>

</main>
<!-- FOOTER -->


